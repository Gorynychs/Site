{
  "name": "freight-site-v2",
  "version": "1.0.0",
  "private": true,
  "description": "Производственный сайт грузоперевозок (v2.0 Hardened Architecture)",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "echo '[ЭТАП 3] Фронтенд будет запущен позже'",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "echo '[ЭТАП 3] Сборка фронтенда будет настроена позже'",
    "test": "npm run test:backend",
    "test:backend": "cd backend && npm test",
    "db:migrate": "cd backend && npm run db:migrate",
    "db:seed": "cd backend && npm run db:seed",
    "db:rollback": "node scripts/db-rollback.js",
    "backup": "node scripts/db-backup.js",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "pre-deploy": "node scripts/pre-deploy-check.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "husky": "^9.0.6"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}