# ==========================================
# PRODUCTION (Боевой сервер)
# ==========================================
# NODE_ENV=production
# PORT=8080
# DB_URL=postgresql://prod_user:STRONG_PROD_PASS@prod-db.internal:5432/freight_prod
# JWT_SECRET=generate-with-crypto-random-64-bytes
# JWT_EXPIRES_IN=24h
# REDIS_URL=redis://prod-redis.internal:6379/2
# YANDEX_MAPS_API_KEY=your_prod_key_here
# EMAIL_HOST=smtp.your-provider.com
# EMAIL_PORT=465
# EMAIL_USER=noreply@yourdomain.com
# EMAIL_PASS=your_secure_email_pass
# WEBHOOK_SECRET=generate-with-crypto-random-64-bytes
# LOG_LEVEL=warn
# SENTRY_DSN=https://your-sentry-dsn
# UPTIME_ROBOT_API_KEY=your_uptime_key