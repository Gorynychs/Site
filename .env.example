# ==========================================
# DEVELOPMENT (Локальная разработка)
# ==========================================
NODE_ENV=development
PORT=3000
DB_URL=postgresql://dev_user:dev_pass@localhost:5432/freight_dev
JWT_SECRET=dev-secret-change-in-prod-123456
JWT_EXPIRES_IN=7d
REDIS_URL=redis://localhost:6379/0
YANDEX_MAPS_API_KEY=your_dev_key_here
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USER=dev@freight.local
EMAIL_PASS=devpass
WEBHOOK_SECRET=dev-webhook-secret
LOG_LEVEL=debug

# ==========================================
# STAGING (Тестовый сервер)
# ==========================================
# NODE_ENV=staging
# PORT=3000
# DB_URL=postgresql://staging_user:staging_pass@staging-db.internal:5432/freight_staging
